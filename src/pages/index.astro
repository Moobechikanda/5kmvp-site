---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import HighlightBox from "@/components/HighlightBox.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";

// --- Fetch posts ---
const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);

type PostType = typeof sortedPosts[number];

const featuredPosts = sortedPosts.filter((post: PostType) => post.data.featured);
const recentPosts = sortedPosts.filter((post: PostType) => !post.data.featured);

// --- Category highlights ---
const highlightCategories = ["tools", "marketing", "productivity"];

const categoryHighlights = highlightCategories.map((category) => {
  const postsInCategory = sortedPosts.filter((post: PostType) =>
    post.data.tags?.includes(category)
  );

  const uniquePosts = Array.from(
    new Map(postsInCategory.map((p: PostType) => [p.slug, p])).values()
  );

  return {
    category,
    posts: uniquePosts.slice(0, 2),
  };
});

// --- Highlight blocks ---
const highlightBlocks = [
  {
    title: "Productivity Tools",
    items: [
      "Use Notion or ClickUp to manage your workflow",
      "Automate repetitive tasks using Zapier",
      "Track your daily output and optimize your time",
    ],
  },
  {
    title: "Marketing Tools",
    items: [
      "Use email tools like ConvertKit",
      "Schedule content with Buffer",
      "Analyze traffic using Google Analytics",
    ],
  },
  {
    title: "Business Tools",
    items: [
      "Use Stripe or PayPal for payments",
      "Build landing pages with Webflow",
      "Use Canva for design work",
    ],
  },
];

// --- Author ---
const authors = [
  {
    name: "Moobe Chikanda",
    bio: "Helping solopreneurs build, launch, and scale using the best tools and systems",
    image: "/images/home.png",
  },
];

// --- FAQ ---
const faqItems = [
  {
    question: "What do solopreneurs need?",
    answer: "Solopreneurs need tools, skills, and systems to run efficiently.",
  },
  {
    question: "How to succeed as a solopreneur?",
    answer: "Success comes from systems and leverage.",
  },
  {
    question: "What skills are useful for solopreneurs?",
    answer: "Marketing, copywriting, design, and problem-solving.",
  },
  {
    question: "What tools do solopreneurs use daily?",
    answer: "Notion, Canva, Zapier.",
  },
  {
    question: "How do solopreneurs stay productive?",
    answer: "Systems, focus, and consistency.",
  },
];

// --- VIDEO SCHEMA ---
const videoStructuredData = {
  "@context": "https://schema.org",
  "@type": "VideoObject",
  "name": "How to Succeed as a Solopreneur",
  "description": "Learn how to build and scale your solopreneur business.",
  "thumbnailUrl": `${SITE.website}/images/hero.jpg`,
  "uploadDate": "2026-04-09",
  "contentUrl": `${SITE.website}/video/how-to-succeed-as-a-solopreneur.mp4`,
  "embedUrl": `${SITE.website}/video/how-to-succeed-as-a-solopreneur.mp4`,
  "publisher": {
    "@type": "Organization",
    "name": "5kmvp"
  }
};

// --- SAFE IMAGE HANDLER ---
const getOgImage = (post: PostType): string => {
  const img = post.data.ogImage;

  if (!img) return "/images/home.png";
  if (typeof img === "string") return img;

  return img.src || "/images/home.png";
};
---

<Layout title={`Tools for Solopreneurs | ${SITE.title}`}>

  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(videoStructuredData)}
  />

  <Header />

  <main id="main-content" class="app-layout">

    <!-- HERO -->
    <section class="py-16 bg-gray-50 dark:bg-gray-900">
      {sortedPosts.length > 0 && (
        <a
          href={`/posts/${sortedPosts[0].slug}/`}
          class="block w-full max-w-6xl mx-auto px-4 rounded-xl overflow-hidden shadow-lg"
        >
          <img
            src={getOgImage(sortedPosts[0])}
            alt={sortedPosts[0].data.title}
            class="w-full rounded-lg mb-6"
          />

          <div class="mt-6 text-center">
            <h1 class="text-4xl font-bold mb-3">
              {sortedPosts[0].data.title}
            </h1>
            <p class="text-lg text-gray-600 dark:text-gray-300">
              {sortedPosts[0].data.description}
            </p>
          </div>
        </a>
      )}
    </section>

    <!-- VIDEO -->
    <section class="max-w-5xl mx-auto px-4 py-16 text-center">
      <h2 class="text-3xl font-bold mb-6">
        How to Succeed as a Solopreneur
      </h2>

      <video controls class="w-full rounded-xl shadow-lg">
        <source src="/video/how-to-succeed-as-a-solopreneur.mp4" type="video/mp4" />
      </video>
    </section>

    <!-- AUTHOR -->
    <section class="max-w-7xl mx-auto px-4 py-12 border-y">
      {authors.map((author) => (
        <div class="flex items-center gap-4">
          <img src={author.image} class="w-20 h-20 rounded-full" />
          <div>
            <h3 class="text-xl font-semibold">{author.name}</h3>
            <p>{author.bio}</p>
          </div>
        </div>
      ))}
    </section>

    <!-- HIGHLIGHTS -->
    <section class="max-w-7xl mx-auto px-4 py-12">
      <div class="grid md:grid-cols-3 gap-8">
        {highlightBlocks.map((block) => (
          <HighlightBox title={block.title}>
            <ul class="space-y-2">
              {block.items.map((item) => <li>{item}</li>)}
            </ul>
          </HighlightBox>
        ))}
      </div>
    </section>

    <!-- FEATURED -->
    {featuredPosts.length > 0 && (
      <section class="max-w-7xl mx-auto px-4 py-12">
        <h2 class="text-3xl font-bold mb-6">Featured</h2>
        <div class="grid md:grid-cols-3 gap-6">
          {featuredPosts.map((post) => (
            <Card {...post} href={`/posts/${post.slug}/`} />
          ))}
        </div>
      </section>
    )}

    <!-- LATEST -->
    <section class="max-w-7xl mx-auto px-4 py-12">
      <h2 class="text-3xl font-bold mb-6">Latest Articles</h2>

      <div class="grid md:grid-cols-3 gap-6">
        {recentPosts.slice(0, SITE.postPerIndex).map((post) => (
          <a href={`/posts/${post.slug}/`} class="block">
            <img src={getOgImage(post)} class="rounded mb-2" />
            <h3>{post.data.title}</h3>
          </a>
        ))}
      </div>
    </section>

    <!-- CATEGORY -->
    <section class="max-w-7xl mx-auto px-4 py-12">
      <h2 class="text-3xl font-bold mb-6">Explore by Category</h2>

      <div class="grid md:grid-cols-3 gap-8">
        {categoryHighlights.map(({ category, posts }) => (
          <div>
            <h3 class="text-xl font-semibold capitalize mb-3">
              {category}
            </h3>

            {posts.length === 0 ? (
              <p>No posts yet</p>
            ) : (
              posts.map((post) => (
                <a href={`/posts/${post.slug}/`} class="block mb-2">
                  <h4>{post.data.title}</h4>
                </a>
              ))
            )}
          </div>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <section class="max-w-7xl mx-auto px-4 py-12 bg-gray-50 dark:bg-gray-900 rounded-xl">
      <h2 class="text-3xl font-bold mb-6">Frequently Asked Questions</h2>

      <div class="space-y-6">
        {faqItems.map((item) => (
          <div class="p-6 rounded-xl shadow">
            <h3 class="font-semibold mb-2">{item.question}</h3>
            <p>{item.answer}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <div class="text-center my-10">
      <LinkButton href="/posts/">
        All Posts
        <IconArrowRight />
      </LinkButton>
    </div>

  </main>

  <Footer />
</Layout>