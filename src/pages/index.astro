---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import HighlightBox from "@/components/HighlightBox.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import ToolScout from "@/components/ToolScout";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);

type PostType = typeof sortedPosts[number];

const featuredPosts = sortedPosts.filter(p => p.data.featured);
const recentPosts = sortedPosts.filter(p => !p.data.featured);

// Fix: case-insensitive tag matching so "Tools", "tools", "TOOLS" all match
const highlightCategories = ["tools", "marketing", "productivity"];

const categoryHighlights = highlightCategories.map(category => {
  const postsInCategory = sortedPosts.filter(p =>
    p.data.tags?.some(tag => tag.toLowerCase() === category.toLowerCase())
  );
  return {
    category,
    posts: postsInCategory.slice(0, 2),
  };
});

const highlightBlocks = [
  {
    title: "Productivity Tools",
    items: ["Notion", "ClickUp", "Zapier"],
  },
  {
    title: "Marketing Tools",
    items: ["ConvertKit", "Buffer", "Google Analytics"],
  },
  {
    title: "Business Tools",
    items: ["Stripe", "Webflow", "Canva"],
  },
];

const authors = [
  {
    name: "Moobe Chikanda",
    bio: "Helping solopreneurs build systems that scale",
    image: "/images/home.png",
  },
];

const faqItems = [
  {
    question: "What do solopreneurs need to succeed in 2026?",
    answer:
      "Solopreneurs need three core things: tools, systems, and skills. Tools help you execute faster (like Notion, Canva, Zapier), systems help you stay organized (like workflows, automation, and templates), and skills like marketing, copywriting, and sales help you generate income. Without all three working together, growth becomes inconsistent and slow.",
  },
  {
    question: "How do I choose the best tools as a solopreneur?",
    answer:
      "The best tools are not the most popular ones — they are the ones that reduce friction in your workflow. Choose tools based on ease of use, integration, cost efficiency, and stage of business. Beginners should focus on Notion, Canva, and Google Workspace.",
  },
  {
    question: "What tools do most successful solopreneurs use daily?",
    answer:
      "Most successful solopreneurs rely on Notion, Canva, Zapier, Google Docs/Sheets, and AI tools like ChatGPT. The key is not using many tools, but building a simple system.",
  },
  {
    question: "How do solopreneurs stay productive without burnout?",
    answer:
      "Productivity comes from systems, not motivation. Time blocking, automation, templates, and focusing on high-impact tasks prevent burnout.",
  },
  {
    question: "Can solopreneurs build profitable businesses alone?",
    answer:
      "Yes. AI, automation, and digital products now allow solopreneurs to build 6-figure businesses without employees.",
  },
  {
    question: "What skills are useful to become a successful solopreneur?",
    answer:
      "Marketing, copywriting, sales, problem-solving, and basic tech skills are the most important.",
  },
  {
    question: "What skills do you need to become a solopreneur?",
    answer:
      "Communication, digital marketing, content creation, automation tools, and adaptability are essential.",
  },
  {
    question: "Can a solopreneur be a CEO?",
    answer:
      "Yes — and many are. As a solopreneur, you are the CEO, CMO, CFO, and everything in between. You set the vision, make the decisions, and own the outcomes. Some solopreneurs formally register as a company and hold the CEO title legally. Whether or not you use the title, you are running a business and leading it.",
  },
  {
    question: "Are solopreneurs booming?",
    answer:
      "Absolutely. The solopreneur economy is one of the fastest-growing segments of the workforce. Thanks to AI, automation, no-code tools, and the rise of the creator economy, more people than ever are building profitable one-person businesses. Reports estimate tens of millions of solopreneurs are now operating globally, and the trend accelerated significantly after 2020.",
  },
  {
    question: "What are some solopreneur business ideas?",
    answer:
      "Some of the most successful solopreneur business ideas include: freelance writing or copywriting, social media management, AI-powered content creation, selling digital products (templates, courses, eBooks), affiliate marketing blogs or newsletters, SaaS micro-tools, consulting or coaching, and niche e-commerce. The best idea is one that combines a skill you have with a problem people will pay to solve.",
  },
];

const getOgImage = (post: PostType) =>
  typeof post.data.ogImage === "string"
    ? post.data.ogImage
    : post.data.ogImage?.src || "/images/home.png";
---

<Layout title={`Best Tools for Solopreneurs | ${SITE.title}`}>

{/* ================= SEO SCHEMA BLOCKS ================= */}
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: SITE.title,
  description: SITE.desc,
  url: SITE.url,
  author: {
    "@type": "Person",
    name: "Moobe Chikanda",
  },
})} />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map(f => ({
    "@type": "Question",
    name: f.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: f.answer,
    },
  })),
})} />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: SITE.url,
    },
  ],
})} />
{/* =================================================== */}

<Header />

<main class="app-layout">

  <!-- ================================================ -->
  <!-- HERO — clear headline replacing random post link -->
  <!-- ================================================ -->
  <section class="py-12 text-center sm:py-20">
    <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-accent">
      The Solopreneur's Toolkit
    </p>
    <h1 class="mb-4 text-3xl font-bold leading-tight sm:text-5xl">
      Build, Automate & Scale —<br class="hidden sm:block" /> Without a Team
    </h1>
    <p class="mx-auto mb-8 max-w-xl text-base text-subtle sm:text-lg">
      Honest reviews, rankings, and guides on the best tools for solopreneurs in 2026. No fluff. No 40-tool lists. Just what works.
    </p>
    <div class="flex flex-col items-center justify-center gap-3 sm:flex-row">
      <LinkButton href="/posts/">
        Browse All Posts <IconArrowRight />
      </LinkButton>
      <a
        href="#featured"
        class="rounded-lg border border-border px-5 py-2 text-sm font-medium transition hover:border-accent hover:text-accent"
      >
        Start Here ↓
      </a>
    </div>
  </section>

  <!-- ================================================ -->
  <!-- AUTHOR — who is behind this site                 -->
  <!-- ================================================ -->
  <section class="pb-10">
    <div class="flex flex-col items-center gap-4 rounded-xl p-6 sm:flex-row sm:gap-6" style="background-color: var(--muted);">
      <img
        src={authors[0].image}
        alt={authors[0].name}
        class="h-20 w-20 flex-shrink-0 rounded-full object-cover ring-2 ring-accent"
      />
      <div class="text-center sm:text-left">
        <p class="text-xs font-semibold uppercase tracking-widest text-accent">Written by</p>
        <h2 class="mt-1 text-lg font-bold">{authors[0].name}</h2>
        <p class="mt-1 text-sm text-subtle">{authors[0].bio}</p>
      </div>
    </div>
  </section>

  <!-- ================================================ -->
  <!-- FEATURED POSTS                                   -->
  <!-- ================================================ -->
  <section id="featured" class="py-12">
    <h2 class="mb-6 text-2xl font-bold sm:text-3xl">Featured Posts</h2>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      {featuredPosts.map(post => (
        <Card {...post} href={`/posts/${post.slug}/`} />
      ))}
    </div>
  </section>

  <!-- ================================================ -->
  <!-- LATEST POSTS — now with image + description      -->
  <!-- ================================================ -->
  <section class="py-12">
    <h2 class="mb-6 text-2xl font-bold sm:text-3xl">Latest Posts</h2>
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 md:grid-cols-3">
      {recentPosts.map(post => (
        <a
          href={`/posts/${post.slug}/`}
          class="group flex flex-col gap-2 rounded-xl border border-border p-4 transition hover:border-accent"
        >
          <img
            src={getOgImage(post)}
            alt={post.data.title}
            loading="lazy"
            class="w-full rounded-lg object-cover"
            style="aspect-ratio: 16/9;"
          />
          <h3 class="text-sm font-semibold leading-snug group-hover:text-accent">
            {post.data.title}
          </h3>
          {post.data.description && (
            <p class="line-clamp-2 text-xs text-subtle">{post.data.description}</p>
          )}
        </a>
      ))}
    </div>
  </section>

  <!-- ================================================ -->
  <!-- TOOLS BY CATEGORY (highlight boxes)              -->
  <!-- ================================================ -->
  <section class="py-12">
    <h2 class="mb-6 text-2xl font-bold sm:text-3xl">Tools by Category</h2>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 md:grid-cols-3">
      {highlightBlocks.map(block => (
        <HighlightBox title={block.title}>
          <ul class="mt-2 space-y-1">
            {block.items.map(i => <li class="text-sm">{i}</li>)}
          </ul>
        </HighlightBox>
      ))}
    </div>
  </section>

  <!-- ================================================ -->
  <!-- EXPLORE BY CATEGORY — with empty state fallback  -->
  <!-- ================================================ -->
  <section class="py-12">
    <h2 class="mb-6 text-2xl font-bold sm:text-3xl">Explore by Category</h2>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 md:grid-cols-3">
      {categoryHighlights.map(c => (
        <div class="rounded-xl border border-border p-5">
          <h3 class="mb-3 font-bold capitalize text-accent">{c.category}</h3>
          {c.posts.length > 0 ? (
            <div class="flex flex-col gap-3">
              {c.posts.map(p => (
                <a
                  href={`/posts/${p.slug}/`}
                  class="block text-sm leading-snug hover:text-accent"
                >
                  → {p.data.title}
                </a>
              ))}
            </div>
          ) : (
            <p class="text-sm text-subtle italic">Posts coming soon.</p>
          )}
        </div>
      ))}
    </div>
  </section>

  <!-- ================================================ -->
  <!-- VIDEO — fixed: height:0 + overflow:hidden needed -->
  <!-- ================================================ -->
  <section class="py-12">
    <h2 class="mb-6 text-center text-2xl font-bold sm:text-3xl">Watch: Start Here</h2>
    <div class="relative w-full overflow-hidden rounded-lg" style="padding-bottom: 56.25%; height: 0;">
      <iframe
        class="absolute left-0 top-0 h-full w-full"
        src="https://www.youtube.com/embed/SLo8Iyc8gmU"
        title="5kmvp intro video"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
      />
    </div>
  </section>

  <!-- ================================================ -->
  <!-- TOOLSCOUT                                        -->
  <!-- ================================================ -->
  <section class="py-16">
    <h2 class="mb-2 text-center text-2xl font-bold sm:text-3xl">
      🔥 Live Tool Rankings & Reviews
    </h2>
    <p class="mb-10 text-center text-subtle">
      Ranked by real data from G2, Product Hunt, Reddit, Trustpilot & Quora
    </p>
    <ToolScout client:load />
  </section>

  <!-- ================================================ -->
  <!-- FAQ — collapsible with <details>/<summary>       -->
  <!-- ================================================ -->
  <section class="rounded-xl px-6 py-10 sm:px-8" style="background-color: var(--muted);">
    <h2 class="mb-6 text-2xl font-bold sm:text-3xl">
      Frequently Asked Questions
    </h2>
    <div class="space-y-3">
      {faqItems.map((f, i) => (
        <details
          class="group rounded-xl shadow-sm"
          style="background-color: var(--card);"
          open={i === 0}
        >
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 font-semibold sm:text-lg">
            <span>{f.question}</span>
            <span class="flex-shrink-0 text-accent transition-transform duration-200 group-open:rotate-45">
              +
            </span>
          </summary>
          <div class="border-t border-border px-5 pb-5 pt-4">
            <p class="text-sm text-subtle sm:text-base">{f.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </section>

  <!-- ================================================ -->
  <!-- CTA — stronger closing section                   -->
  <!-- ================================================ -->
  <section class="py-16 text-center">
    <h2 class="mb-3 text-2xl font-bold sm:text-3xl">Ready to find the right tools?</h2>
    <p class="mb-6 text-subtle">Browse all our guides, reviews, and comparisons.</p>
    <LinkButton href="/posts/">
      View All Posts <IconArrowRight />
    </LinkButton>
  </section>

</main>

<Footer />

</Layout>