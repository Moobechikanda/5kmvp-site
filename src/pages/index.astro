---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import HighlightBox from "@/components/HighlightBox.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import ToolScout from "@/components/ToolScout";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);

type PostType = typeof sortedPosts[number];

const featuredPosts = sortedPosts.filter(p => p.data.featured);
const recentPosts = sortedPosts.filter(p => !p.data.featured);

const highlightCategories = ["tools", "marketing", "productivity"];

const categoryHighlights = highlightCategories.map(category => {
  const postsInCategory = sortedPosts.filter(p =>
    p.data.tags?.includes(category)
  );

  return {
    category,
    posts: postsInCategory.slice(0, 2),
  };
});

const highlightBlocks = [
  {
    title: "Productivity Tools",
    items: ["Notion", "ClickUp", "Zapier"],
  },
  {
    title: "Marketing Tools",
    items: ["ConvertKit", "Buffer", "Google Analytics"],
  },
  {
    title: "Business Tools",
    items: ["Stripe", "Webflow", "Canva"],
  },
];

const authors = [
  {
    name: "Moobe Chikanda",
    bio: "Helping solopreneurs build systems that scale",
    image: "/images/home.png",
  },
];

const faqItems = [
  {
    question: "What do solopreneurs need to succeed in 2026?",
    answer:
      "Solopreneurs need three core things: tools, systems, and skills. Tools help you execute faster (like Notion, Canva, Zapier), systems help you stay organized (like workflows, automation, and templates), and skills like marketing, copywriting, and sales help you generate income. Without all three working together, growth becomes inconsistent and slow.",
  },
  {
    question: "How do I choose the best tools as a solopreneur?",
    answer:
      "The best tools are not the most popular ones — they are the ones that reduce friction in your workflow. Choose tools based on ease of use, integration, cost efficiency, and stage of business. Beginners should focus on Notion, Canva, and Google Workspace.",
  },
  {
    question: "What tools do most successful solopreneurs use daily?",
    answer:
      "Most successful solopreneurs rely on Notion, Canva, Zapier, Google Docs/Sheets, and AI tools like ChatGPT. The key is not using many tools, but building a simple system.",
  },
  {
    question: "How do solopreneurs stay productive without burnout?",
    answer:
      "Productivity comes from systems, not motivation. Time blocking, automation, templates, and focusing on high-impact tasks prevent burnout.",
  },
  {
    question: "Can solopreneurs build profitable businesses alone?",
    answer:
      "Yes. AI, automation, and digital products now allow solopreneurs to build 6-figure businesses without employees.",
  },
  {
    question: "What skills are useful to become a successful solopreneur?",
    answer:
      "Marketing, copywriting, sales, problem-solving, and basic tech skills are the most important.",
  },
  {
    question: "What skills do you need to become a solopreneur?",
    answer:
      "Communication, digital marketing, content creation, automation tools, and adaptability are essential.",
  },
];

const getOgImage = (post: PostType) =>
  typeof post.data.ogImage === "string"
    ? post.data.ogImage
    : post.data.ogImage?.src || "/images/home.png";
---

<Layout title={`Best Tools for Solopreneurs | ${SITE.title}`}>

{/* ================= SEO SCHEMA BLOCKS ================= */}
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: `Best Tools for Solopreneurs | ${SITE.title}`,
  description: SITE.desc,
  author: {
    "@type": "Person",
    name: "Moobe Chikanda",
  },
  mainEntityOfPage: SITE.url,
})} />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map(f => ({
    "@type": "Question",
    name: f.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: f.answer,
    },
  })),
})} />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: SITE.url,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Solopreneur Tools",
      item: SITE.url + "/",
    },
  ],
})} />
{/* =================================================== */}

<Header />

<main class="app-layout">

<!-- HERO -->
<section class="py-16 text-center">
  {sortedPosts.length > 0 && (
    <a href={`/posts/${sortedPosts[0].slug}/`}>
      <img src={getOgImage(sortedPosts[0])} class="mx-auto rounded-lg" />
      <h1 class="text-4xl font-bold mt-4">
        {sortedPosts[0].data.title}
      </h1>
    </a>
  )}
</section>

<!-- SEO INTRO -->
<section class="max-w-3xl mx-auto text-center py-6">
  This site helps solopreneurs discover tools to build, automate, and scale.
</section>

<!-- START HERE -->
<section class="text-center py-10">
  <h2 class="text-2xl font-bold">Start Here</h2>
</section>

<!-- VIDEO -->
<section class="py-12 text-center">
  <iframe
    width="800"
    height="450"
    src="https://www.youtube.com/embed/SLo8Iyc8gmU"
  />
</section>

<!-- AUTHOR -->
<section class="py-10 text-center">
  {authors.map(a => (
    <div>
      <img src={a.image} class="w-20 h-20 rounded-full mx-auto" />
      <h3>{a.name}</h3>
      <p>{a.bio}</p>
    </div>
  ))}
</section>

<!-- HIGHLIGHTS -->
<section class="grid md:grid-cols-3 gap-6 max-w-6xl mx-auto py-12">
  {highlightBlocks.map(block => (
    <HighlightBox title={block.title}>
      <ul>
        {block.items.map(i => <li>{i}</li>)}
      </ul>
    </HighlightBox>
  ))}
</section>

<!-- FEATURED POSTS -->
<section class="max-w-6xl mx-auto py-12">
  <h2 class="text-3xl font-bold mb-6">Featured Posts</h2>
  <div class="grid md:grid-cols-3 gap-6">
    {featuredPosts.map(post => (
      <Card {...post} href={`/posts/${post.slug}/`} />
    ))}
  </div>
</section>

<!-- LATEST POSTS -->
<section class="max-w-6xl mx-auto py-12">
  <h2 class="text-3xl font-bold mb-6">Latest Posts</h2>
  <div class="grid md:grid-cols-3 gap-6">
    {recentPosts.map(post => (
      <a href={`/posts/${post.slug}/`}>
        <h3>{post.data.title}</h3>
      </a>
    ))}
  </div>
</section>

<!-- CATEGORY -->
<section class="max-w-6xl mx-auto py-12">
  <h2 class="text-3xl font-bold mb-6">Explore by Category</h2>

  <div class="grid md:grid-cols-3 gap-8">
    {categoryHighlights.map(c => (
      <div>
        <h3 class="font-bold">{c.category}</h3>
        {c.posts.map(p => (
          <a href={`/posts/${p.slug}/`}>{p.data.title}</a>
        ))}
      </div>
    ))}
  </div>
</section>

<!-- TOOLSCOUT -->
<section class="max-w-6xl mx-auto py-16">
  <h2 class="text-3xl font-bold text-center mb-2">
    🔥 Live Tool Rankings & Reviews
  </h2>
  <p class="text-center text-gray-500 dark:text-gray-400 mb-10">
    Ranked by real data from G2, Product Hunt, Reddit, Trustpilot & Quora
  </p>
  <ToolScout client:load />
</section>

<!-- FAQ -->
<section class="max-w-7xl mx-auto px-4 py-12 bg-gray-50 dark:bg-gray-900 rounded-xl">
  <h2 class="text-3xl font-bold mb-6">
    Frequently Asked Questions (Solopreneur Tools Guide)
  </h2>
  <div class="space-y-6">
    {faqItems.map(f => (
      <div class="p-6 rounded-xl shadow bg-white dark:bg-gray-800">
        <h3 class="font-semibold mb-2 text-lg">{f.question}</h3>
        <p>{f.answer}</p>
      </div>
    ))}
  </div>
</section>

<!-- CTA -->
<section class="text-center py-10">
  <LinkButton href="/posts/">
    View All Posts <IconArrowRight />
  </LinkButton>
</section>

</main>

<Footer />

</Layout>