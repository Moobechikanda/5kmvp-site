---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import getSortedPosts from "@/utils/getSortedPosts";

// Generate static paths for ALL posts
export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

if (!post) {
  return Astro.redirect("/404");
}

const { Content } = await post.render();

// Get all posts sorted
const sortedPosts = getSortedPosts(await getCollection("blog"));

// Determine previous and next posts for navigation
const currentIndex = sortedPosts.findIndex(p => p.slug === post.slug);
const prevPost = sortedPosts[currentIndex - 1] || null;
const nextPost = sortedPosts[currentIndex + 1] || null;

// Get related posts based on shared tags
const relatedPosts = sortedPosts
  .filter(
    p =>
      p.slug !== post.slug &&
      p.data.tags?.some(tag => post.data.tags?.includes(tag))
  )
  .slice(0, 3);
---

<Layout title={post.data.title} description={post.data.description}>
  <main class="max-w-4xl mx-auto px-4 py-12">

    <!-- Back to homepage -->
    <a href="/" class="text-blue-600 hover:underline mb-6 inline-block">
      ← 5kmvp
    </a>

    <!-- Post title -->
    <h1 class="text-4xl font-bold mb-6">{post.data.title}</h1>

    <!-- Post image -->
    {post.data.ogImage && (
      <img
        src={post.data.ogImage}
        alt={post.data.title}
        class="w-full rounded-lg mb-6"
      />
    )}

    <!-- Post content -->
    <article class="prose dark:prose-invert max-w-none">
      <Content />
    </article>

    <!-- Post navigation -->
    <div class="flex justify-between mt-12">
      {prevPost && (
        <a href={`/posts/${prevPost.slug}/`} class="text-blue-600 hover:underline">
          ← {prevPost.data.title}
        </a>
      )}
      {nextPost && (
        <a href={`/posts/${nextPost.slug}/`} class="text-blue-600 hover:underline ml-auto">
          {nextPost.data.title} →
        </a>
      )}
    </div>

    <!-- Related Articles -->
    {relatedPosts.length > 0 && (
      <>
        <hr class="my-10" />
        <h3 class="text-2xl font-bold mb-4">Related Articles</h3>
        <ul class="space-y-2">
          {relatedPosts.map(rp => (
            <li>
              <a href={`/posts/${rp.slug}/`} class="text-blue-600 hover:underline">
                {rp.data.title}
              </a>
            </li>
          ))}
        </ul>
      </>
    )}

  </main>
</Layout>