---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Cookie Policy">
  <main class="max-w-3xl mx-auto px-4 py-12">
    <h1>Cookie Policy</h1>
    <p>
      This website uses cookies to improve your browsing experience. Cookies are small files stored on your device.
    </p>

    <h2>Types of Cookies</h2>
    <p>We use essential cookies for site functionality and analytics cookies to understand visitor behavior.</p>

    <h2>Managing Cookies</h2>
    <p>You can disable cookies in your browser settings, but some features may not work properly.</p>

    <h2>Contact</h2>
    <p>If you have questions about our cookie policy, please contact us.</p>
  </main>
</Layout>