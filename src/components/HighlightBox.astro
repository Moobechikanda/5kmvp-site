---
const { title } = Astro.props;
---

<div class="highlight-box">
  {title && <h3>{title}</h3>}
  <div class="content">
    <slot />
  </div>
</div>

<style>
.highlight-box {
  background: #f3f4f6;
  border-left: 5px solid #2563eb;
  padding: 1.5rem;
  margin: 2rem 0;
  border-radius: 8px;
}
.highlight-box h3 {
  margin-top: 0;
  margin-bottom: 1rem;
  color: #000000;
}


.highlight-box ul {
  margin: 0;
  padding-left: 1.2rem;
}
</style>
