---
const { title } = Astro.props;
---

<script type="application/ld+json">
{
 "@context": "https://schema.org",
 "@type": "BreadcrumbList",
 "itemListElement": [
  {
   "@type": "ListItem",
   "position": 1,
   "name": "Home",
   "item": "/"
  },
  {
   "@type": "ListItem",
   "position": 2,
   "name": "Blog",
   "item": "/blog"
  },
  {
   "@type": "ListItem",
   "position": 3,
   "name": "{title}"
  }
 ]
}
</script>